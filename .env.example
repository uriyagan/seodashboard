# ==============================================
# SEO Dashboard — Environment Variables (example)
# העתק לקובץ .env.local ומלא ערכים. אל תעלה .env.local ל-git!
# סודות אמיתיים (service_role / Gemini / Resend / encryption)
# יישמרו בפרודקשן כ-Cloudflare Worker Secrets, לא בקובץ.
# ==============================================

# --- Supabase (client-safe) ---
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# --- Supabase (server-side only — Worker secret) ---
SUPABASE_SERVICE_ROLE_KEY=

# --- Gemini (server-side only — Worker secret) ---
GEMINI_API_KEY=

# --- Resend (server-side only — Worker secret) ---
RESEND_API_KEY=

# --- הצפנת פרטי חיבור WordPress (server-side only — Worker secret) ---
ENCRYPTION_KEY=
