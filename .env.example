# ==============================================
# SEO Dashboard — Environment Variables (example)
# העתק לקובץ .env.local ומלא ערכים. אל תעלה .env.local ל-git!
# בפרודקשן: הערכים ללא VITE_ נשמרים כ-Cloudflare Worker Secrets.
# ==============================================

# --- Supabase (client / VITE) ---
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# --- Supabase (Worker side) ---
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=sb_publishable_xxx
SUPABASE_SERVICE_ROLE_KEY=            # נדרש לניטור ה-Cron (Phase 7)

# --- Gemini (Worker Secret) ---
GEMINI_API_KEY=
GEMINI_TEXT_MODEL=gemini-3.1-pro-preview    # ברירת מחדל אם ריק
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image   # Nano Banana 2

# --- Resend (Worker Secret) ---
RESEND_API_KEY=
RESEND_FROM=SEO Dashboard <noreply@mail.uriyaganor.com>
ADMIN_EMAILS=info@uriyaganor.com,sam@uriyaganor.com

# --- הצפנת פרטי WordPress (Worker Secret) ---
ENCRYPTION_KEY=                        # base64 של 32 בתים

# --- כללי ---
APP_URL=https://seo.uriyaganor.com
